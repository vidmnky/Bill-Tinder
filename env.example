# =============================================
# LegisSwipe Environment Variables
# Copy this to .env.local and fill in your keys
# NEVER commit .env.local to git
# =============================================

# Congress.gov API — register at https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# LegiScan API — register at https://legiscan.com/legiscan
LEGISCAN_API_KEY=

# Groq API — register at https://console.groq.com
GROQ_API_KEY=

# Supabase — create a project at https://supabase.com
# Found in: Project Settings > API > "Your new API keys are here"
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Cron secret — generate any random string, e.g.: openssl rand -hex 32
# This protects your cron endpoints from being called by anyone but Vercel
CRON_SECRET=

# Civic Mirror Basin API (primary bill source)
# Bills are fetched from the CM universal bill basin instead of Congress.gov/LegiScan directly
BASIN_API_URL=https://determined-presence-production-cd4f.up.railway.app
BASIN_API_KEY=
